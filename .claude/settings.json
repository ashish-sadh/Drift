{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/require-read-before-edit.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-testflight.sh",
            "timeout": 600
          },
          {
            "type": "command",
            "command": ".claude/hooks/issue-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/boy-scout.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(gh issue close *)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/enforce-close-comment.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/cycle-counter.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/testflight-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/coverage-gate.sh",
            "timeout": 300
          },
          {
            "type": "command",
            "command": ".claude/hooks/daily-report.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/mark-in-progress.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/ensure-clean-state.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
