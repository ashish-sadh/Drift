# Local API keys — never commit
.drift-secrets/
*.anthropic-key
/tmp/drift-test-*

# Heartbeat snapshot is written to disk by the watchdog on each tick but
# NOT committed — avoids polluting git log (#642). command-center reads
# it from disk locally; the file stays tracked for backwards compat but
# the watchdog no longer creates standalone heartbeat commits.
command-center/heartbeat.json
