# Local API keys — never commit
.drift-secrets/
*.anthropic-key
/tmp/drift-test-*

# Heartbeat snapshot is committed by the watchdog on a rate-limited
# schedule (max once per 10 min, plus piggybacking on any new commit on
# main), so no gitignore — keep it in-tree so the deployed Pages view
# can read it.
